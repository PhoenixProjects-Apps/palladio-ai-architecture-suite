{
  "name": "UserCredits",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "tokens": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "user_email"
  ],
  "rls": {
    "create": {
      "data.user_email": "{{user.email}}"
    },
    "read": {
      "data.user_email": "{{user.email}}"
    },
    "update": {
      "data.user_email": "{{user.email}}"
    },
    "delete": {
      "data.user_email": "{{user.email}}"
    }
  }
}