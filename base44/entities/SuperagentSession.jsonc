{
  "name": "SuperagentSession",
  "type": "object",
  "properties": {
    "session_id": {
      "type": "string"
    },
    "owner_email": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    }
  },
  "required": [
    "session_id",
    "owner_email"
  ],
  "rls": {
    "create": {
      "created_by_id": "{{user.id}}"
    },
    "read": {
      "created_by_id": "{{user.id}}"
    },
    "update": {
      "created_by_id": "{{user.id}}"
    },
    "delete": {
      "created_by_id": "{{user.id}}"
    }
  }
}